# Clampd Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── License (required) ────────────────────────────────────────────
# Get your license at https://clampd.dev
# Generate with: ./generate-license.sh design_partner <org-id>
CLAMPD_LICENSE_KEY=

# ─── Security (REQUIRED) ─────────────────────────────────────────
# All secrets below MUST be set. The stack will refuse to start without them.

# REQUIRED — Generate with: openssl rand -hex 32
# Must be at least 32 characters. Do NOT use the old default value.
JWT_SECRET=

# REQUIRED — Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# REQUIRED — Generate with: openssl rand -hex 16
REDIS_PASSWORD=

# REQUIRED — Generate with: openssl rand -hex 64
# Used for internal service-to-service authentication.
AG_INTERNAL_SECRET=

# REQUIRED — Generate with: openssl rand -hex 32
# Token for NATS message bus authentication.
NATS_TOKEN=

# ─── Optional ──────────────────────────────────────────────────────
# MODEL_ESCALATION_ENABLED=false
# PII_NER_ENABLED=true
# PII_TOKENIZATION_ENABLED=false
# CLAMPD_SAAS_URL=        # Leave empty for standalone mode (no cloud connection)

# ─── Gateway TLS (HIPAA/PCI-DSS compliance) ─────────────────────
# External-facing TLS for ag-gateway HTTP listener.
# Generate self-signed: ./generate-tls.sh gateway.example.com
# For production, use Let's Encrypt (via Caddy) or your CA's cert.
# CLAMPD_TLS_CERT=/tls/clampd-gateway.pem
# CLAMPD_TLS_KEY=/tls/clampd-gateway-key.pem
# CLAMPD_ENV=production     # Enforces TLS — gateway refuses to start without cert/key

# ─── gRPC TLS (internal service-to-service) ──────────────────────
# When set, all gRPC servers use TLS and clients verify server certs.
# Omit all three to run plaintext gRPC (suitable for dev/Docker networks).
# AG_GRPC_TLS_CERT=/certs/server.pem
# AG_GRPC_TLS_KEY=/certs/server-key.pem
# AG_GRPC_TLS_CA=/certs/ca.pem

# ─── Detection Tuning (all optional, sensible defaults) ──────────
# Session detection thresholds:
# CLAMPD_SESSION_TTL_SECS=1800           # Session sliding window (30 min)
# CLAMPD_RAPID_FIRE_THRESHOLD=20         # Calls in window for rapid-fire detection
# CLAMPD_RAPID_FIRE_WINDOW_SECS=60       # Rapid-fire detection window
# CLAMPD_SCOPE_PROBE_THRESHOLD=3         # Denied requests for scope probing
# CLAMPD_MAX_SESSION_RISK=0.6            # Max session risk cap

# Rule engine thresholds:
# CLAMPD_TOOL_DIVERSITY_THRESHOLD=5      # Min distinct tools for diversity spike
# CLAMPD_VOLUME_ANOMALY_MULTIPLIER=5     # Volume anomaly: calls vs baseline ratio
# CLAMPD_SLOW_DRIP_MULTIPLIER=2          # 7-day slow-drip detection ratio
# CLAMPD_SLOW_DRIP_MIN_RECORDS=1000      # Min extracted records for slow-drip alert

# Model escalation (LLM judge):
# CLAMPD_LLM_JUDGE_LOW=0.2              # Gray zone lower bound
# CLAMPD_LLM_JUDGE_HIGH=0.75            # Gray zone upper bound

# Delegation:
# CLAMPD_MAX_DELEGATION_DEPTH=5          # Max agent-to-agent delegation chain depth

# Caching:
# CLAMPD_BASELINE_CACHE_TTL_SECS=60     # Baseline cache refresh interval

# Shadow (audit log) thresholds:
# CLAMPD_SHADOW_LAG_WARN=10000          # Consumer lag warning threshold
# CLAMPD_SHADOW_LAG_CRITICAL=100000     # Consumer lag critical threshold
