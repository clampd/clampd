# Clampd Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── License (required) ────────────────────────────────────────────
# Get your community license at https://clampd.dev/setup
# Generate with: ./generate-license.sh design_partner <org-id>
CLAMPD_LICENSE_KEY=

# ─── Security (change these in production!) ────────────────────────
JWT_SECRET=change-me-to-a-strong-random-string-32-chars-min
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me

# ─── Optional ──────────────────────────────────────────────────────
# MODEL_ESCALATION_ENABLED=false
# PII_NER_ENABLED=true
# PII_TOKENIZATION_ENABLED=false
# CLAMPD_STANDALONE=false
