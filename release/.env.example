# Clampd Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── License (required) ────────────────────────────────────────────
# Sign up at https://license.clampd.dev to get your license key.
# Then activate: clampd license activate --license "$CLAMPD_LICENSE_KEY"
CLAMPD_LICENSE_KEY=

# ─── Security (REQUIRED) ─────────────────────────────────────────
# All secrets below MUST be set. The stack will refuse to start without them.

# REQUIRED - Generate with: openssl rand -hex 32
# Must be at least 32 characters.
JWT_SECRET=

# REQUIRED - Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# REQUIRED - Generate with: openssl rand -hex 16
REDIS_PASSWORD=

# REQUIRED - Generate with: openssl rand -hex 64
# Used for internal service-to-service authentication.
AG_INTERNAL_SECRET=

# REQUIRED - Generate with: openssl rand -hex 32
# Token for NATS message bus authentication.
NATS_TOKEN=

# ─── Database ────────────────────────────────────────────────────
# Default: local Postgres container. For managed DB (Neon, Supabase):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# REDIS_URL=redis://:password@host:6379

# ─── Dashboard ───────────────────────────────────────────────────
# Required for the dashboard (app.clampd.dev / self-hosted dashboard).
# DASHBOARD_URL=https://app.clampd.dev
# NEXT_PUBLIC_API_URL=https://api.clampd.dev

# Google OAuth (optional - for Google sign-in on dashboard)
# Get credentials at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email notifications (optional - uses Resend)
# RESEND_API_KEY=
# EMAIL_FROM=Clampd <noreply@yourdomain.com>

# SSO callback URL (for enterprise SSO)
# SSO_CALLBACK_URL=https://api.clampd.dev/v1/auth/sso/callback

# ─── ClickHouse (optional - for analytics) ───────────────────────
# CLICKHOUSE_URL=https://host:8443
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# ─── Gateway TLS (HIPAA/PCI-DSS compliance) ─────────────────────
# External-facing TLS for ag-gateway HTTP listener.
# For production, use Let's Encrypt (via Caddy) or your CA's cert.
# CLAMPD_TLS_CERT=/tls/clampd-gateway.pem
# CLAMPD_TLS_KEY=/tls/clampd-gateway-key.pem
# CLAMPD_ENV=production     # Enforces TLS - gateway refuses to start without cert/key

# ─── gRPC TLS (internal service-to-service) ──────────────────────
# When set, all gRPC servers use TLS and clients verify server certs.
# Omit all three to run plaintext gRPC (suitable for dev/Docker networks).
# AG_GRPC_TLS_CERT=/certs/server.pem
# AG_GRPC_TLS_KEY=/certs/server-key.pem
# AG_GRPC_TLS_CA=/certs/ca.pem

# ─── Detection Tuning (all optional, sensible defaults) ──────────
# Session thresholds:
# CLAMPD_SESSION_TTL_SECS=1800
# CLAMPD_RAPID_FIRE_THRESHOLD=20
# CLAMPD_RAPID_FIRE_WINDOW_SECS=60
# CLAMPD_SCOPE_PROBE_THRESHOLD=3
# CLAMPD_MAX_SESSION_RISK=0.6

# Rule engine:
# CLAMPD_TOOL_DIVERSITY_THRESHOLD=5
# CLAMPD_VOLUME_ANOMALY_MULTIPLIER=5
# CLAMPD_SLOW_DRIP_MULTIPLIER=2
# CLAMPD_SLOW_DRIP_MIN_RECORDS=1000

# Model escalation (LLM judge):
# CLAMPD_LLM_JUDGE_LOW=0.2
# CLAMPD_LLM_JUDGE_HIGH=0.75

# Delegation:
# CLAMPD_MAX_DELEGATION_DEPTH=5

# Caching:
# CLAMPD_BASELINE_CACHE_TTL_SECS=60

# Shadow (audit log):
# CLAMPD_SHADOW_LAG_WARN=10000
# CLAMPD_SHADOW_LAG_CRITICAL=100000
